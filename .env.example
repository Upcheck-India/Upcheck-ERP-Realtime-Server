# Port the Socket.IO server listens on (host may override via PORT).
PORT=4001

# Same Atlas cluster as upcheck_admin. This service only READS from it.
MONGODB_URI=
# Database name (matches upcheck_admin's db('resources')).
MONGODB_DB=resources

# MUST be byte-identical to upcheck_admin's REALTIME_JWT_SECRET — this service
# verifies the short-lived socket token that upcheck_admin signs.
REALTIME_JWT_SECRET=

# Comma-separated browser origins allowed to connect (the RN app is unaffected
# since it sends no Origin header).
CORS_ORIGINS=https://erp.upcheck.in

# Presence tuning (optional; defaults shown).
PRESENCE_GRACE_MS=5000
LAST_ACTIVE_BUMP_MS=60000

# App Store storage providers (moved here from upcheck_admin/Vercel — see
# APPSTORE_ROOT_CAUSE_INVESTIGATION.md). Same values as upcheck_admin's
# .env.local — copy them over, don't generate new ones.
BLOB_READ_WRITE_TOKEN=
UPLOADTHING_TOKEN=
